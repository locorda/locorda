---
interface Props {
  title: string;
  description: string;
  showLogo?: boolean;
  primaryCta?: { text: string; href: string; external?: boolean };
  secondaryCta?: { text: string; href: string; external?: boolean };
}

const {
  title,
  description,
  showLogo = true,
  primaryCta,
  secondaryCta,
} = Astro.props;
---

<div class="hero-gradient">
  <div class="container">
    <div class="hero-content">
      <slot name="above-title" />
      <div class="hero-title">
        {
          showLogo && (
            <img src="/logo-light.svg" alt="Locorda Logo" class="hero-logo" />
          )
        }
        <h1>{title}</h1>
      </div>

      <p class="hero-description" set:html={description} />

      {
        (primaryCta || secondaryCta) && (
          <div class="hero-cta">
            {primaryCta && (
              <a
                href={primaryCta.href}
                class="cta-primary"
                {...(primaryCta.external
                  ? { target: "_blank", rel: "noopener" }
                  : {})}
              >
                {primaryCta.text}
              </a>
            )}
            {secondaryCta && (
              <a
                href={secondaryCta.href}
                class="cta-secondary"
                {...(secondaryCta.external
                  ? { target: "_blank", rel: "noopener" }
                  : {})}
              >
                {secondaryCta.text}
              </a>
            )}
          </div>
        )
      }
      <div class="hero-meta">
        <slot name="after-cta" />
      </div>
    </div>

    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>
</div>

<style>
  /* Simple hero for pages without breadcrumbs */
  .hero-gradient {
    padding: 6rem 0;
  }

  .hero-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.25rem;
    opacity: 0.75;
    transition: opacity 0.2s;
  }

  .hero-meta:hover {
    opacity: 1;
  }

  .hero-meta:empty {
    display: none;
  }

  .hero-pill {
    display: flex;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
</style>
